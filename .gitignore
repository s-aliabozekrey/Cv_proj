*.mp4
*.avi
*.mov
*.mkv

# Ignore model weights and exports
*.pt
*.pth
*.onnx

# But track input videos
!data/input_videos/
!data/input_videos/*.mp4
!data/input_videos/*.avi
!data/input_videos/*.mov
!data/input_videos/*.mkv
